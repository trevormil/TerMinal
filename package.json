{
  "name": "terminal",
  "version": "0.1.0",
  "description": "A standalone, local-first software factory for coding agents: hosts the real Claude Code / Codex CLI with a live cockpit, autonomous build loop, scheduling, and cross-repo observability — no server, no account.",
  "author": "Trevor Miller",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trevormil/TerMinal.git"
  },
  "homepage": "https://github.com/trevormil/TerMinal#readme",
  "bugs": "https://github.com/trevormil/TerMinal/issues",
  "main": "out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --mac",
    "release": "bin/release",
    "test": "bun test --path-ignore-patterns vendor",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -o node-pty,better-sqlite3",
    "postinstall": "electron-rebuild -f -o node-pty,better-sqlite3"
  },
  "dependencies": {
    "@codemirror/theme-one-dark": "6.1.3",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@uiw/codemirror-extensions-langs": "4.25.9",
    "@uiw/react-codemirror": "4.25.9",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-web-links": "0.11.0",
    "better-sqlite3": "12.10.0",
    "highlight.js": "11.11.1",
    "lucide-react": "1.16.0",
    "mermaid": "11.16.0",
    "node-pty": "1.0.0",
    "parse-diff": "0.12.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "4.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "1.3.14",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "4.7.0",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "electron": "41.10.1",
    "electron-builder": "26.15.6",
    "electron-vite": "5.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.7.2",
    "vite": "7.3.6"
  },
  "overrides": {
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.0",
    "form-data": "4.0.6",
    "js-yaml": "4.3.0",
    "dompurify": "3.4.11",
    "tar": "7.5.19"
  }
}
