#!/usr/bin/env bash
# activity — append a workflow event to the TerMinal activity feed.
#
#   activity <kind> "<title>" ["<detail>"] [--ticket N] [--pr N]
#
# kinds: session-start | session-end | ticket-filed | ticket-closed | pr-opened |
#        pr-verdict | pr-merged | tests-pass | tests-fail | check | doc |
#        agent-run | task-complete | blocked | error | info
#        (free string; unknown kinds still render with a fallback icon)
#
# --ticket / --pr add the join keys for CYCLE-TIME linkage — they connect a
# ticket's events across its life (ticket-filed → pr-opened{ticket,pr} →
# pr-verdict{pr} → pr-merged{pr} → ticket-closed{ticket}). Pass them whenever the
# id is known so the Factory tab can compute time-to-merge + the funnel.
#
# Appends one JSON line to the global feed; the terminal tails it live. Always
# exits 0, so it never breaks a skill if logging fails.
set -uo pipefail

KIND="${1:-info}"
shift 2>/dev/null || true
TITLE=""
DETAIL=""
TICKET=""
PR=""
pos=()
while [ $# -gt 0 ]; do
  case "$1" in
    --ticket) TICKET="${2:-}"; shift 2 ;;
    --pr) PR="${2:-}"; shift 2 ;;
    *) pos+=("$1"); shift ;;
  esac
done
[ "${#pos[@]}" -ge 1 ] && TITLE="${pos[0]}"
[ "${#pos[@]}" -ge 2 ] && DETAIL="${pos[1]}"

LOG="${GT_ACTIVITY_LOG:-$HOME/.config/TerMinal/activity.jsonl}"
mkdir -p "$(dirname "$LOG")" 2>/dev/null || exit 0
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
REPO="$(git -C "$ROOT" remote get-url origin 2>/dev/null | sed -E 's#\.git$##; s#.*[/:]([^/]+/[^/]+)$#\1#')"
[ -n "$REPO" ] || REPO="$(basename "$ROOT")"

python3 - "$KIND" "$TITLE" "$DETAIL" "$REPO" "$ROOT" "$TICKET" "$PR" >> "$LOG" 2>/dev/null <<'PY' || exit 0
import json, sys, time, uuid
kind, title, detail, repo, root, ticket, pr = sys.argv[1:8]
ev = {
    "id": str(uuid.uuid4()), "ts": int(time.time() * 1000),
    "kind": kind, "title": title, "detail": detail, "repo": repo, "repoRoot": root,
}
ref = {}
if ticket.isdigit():
    ref["ticket"] = int(ticket)
if pr.isdigit():
    ref["pr"] = int(pr)
if ref:
    ev["ref"] = ref
print(json.dumps(ev))
PY
exit 0
