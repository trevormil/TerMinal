#!/usr/bin/env bash
# List sessions from each session.md frontmatter. Optional status filter.
#
#   bin/sessions            # all sessions, newest id first
#   bin/sessions active     # only status: active
#   bin/sessions closed     # only status: closed
#
# Sessions live at <repo>/sessions/NNNN-slug/session.md. Portable (macOS+Linux).
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SESSIONS="$ROOT/sessions"
want_status="${1:-}"

# field <file> <key> -> first frontmatter value for key (quotes stripped)
field() {
  awk -v key="$2" '
    NR==1 && $0=="---" { infm=1; next }
    infm && $0=="---"  { exit }
    infm && $0 ~ "^"key": " {
      sub("^"key": *",""); gsub(/^"|"$/,""); print; exit
    }' "$1"
}

printf '%-6s %-9s %-12s %s\n' ID STATUS STARTED TITLE
printf '%-6s %-9s %-12s %s\n' "----" "------" "-------" "-----"

shopt -s nullglob 2>/dev/null || true
found=""
# newest first
for d in $(ls -1d "$SESSIONS"/[0-9]*/ 2>/dev/null | sort -r); do
  f="$d/session.md"
  [ -e "$f" ] || continue
  found=1
  status="$(field "$f" status)"
  [ -n "$want_status" ] && [ "$status" != "$want_status" ] && continue
  started="$(field "$f" started)"
  printf '%-6s %-9s %-12s %s\n' \
    "$(field "$f" id)" "$status" "${started%%T*}" "$(field "$f" title)"
done
[ -n "$found" ] || echo "(no sessions yet — start one with /session-start)" >&2
