      "paths": ["widgets/repo-pulse/widgets.json"],
      "install": {
        "copyTo": ".TerMinal/widgets.json",
        "merge": "merge by widget id",
        "scope": "repo"
      },
      "tags": ["cockpit", "repo", "workflow"]
    },
    {
      "id": "skills/quick-review",
