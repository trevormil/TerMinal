# Copy to .xcodegen.env (gitignored) and fill in your Apple identifiers, then
# `source .xcodegen.env` (or use bin/generate) before `xcodegen generate`.
# Without these, xcodegen substitutes the fork-safe placeholders below —
# enough to build for the Simulator, not to sign for a device or TestFlight.
export DEVELOPMENT_TEAM="YOUR_TEAM_ID"     # Apple team id, 10 chars
export PRODUCT_BUNDLE_ID="com.example.terminal"
export BUNDLE_ID_PREFIX="com.example"
