# Copy to .testflight.env (gitignored) for scripts/testflight.sh.
# App Store Connect > Users and Access > Integrations > App Store Connect API.
# The Team ID is NOT here — it lives in project.yml (DEVELOPMENT_TEAM).
#
# The key's role must be ADMIN. App Manager can upload builds but cannot create
# the cloud-managed distribution certificate, and the first export then fails
# with a misleading "No profiles were found" error.

# 10-char key id, shown next to the key in the Integrations table.
ASC_KEY_ID=

# UUID shown at the top of the Integrations page.
ASC_ISSUER_ID=

# Optional. Defaults to ~/.appstoreconnect/private_keys/AuthKey_$ASC_KEY_ID.p8
# The .p8 downloads exactly once — never commit it.
#ASC_KEY_PATH=
