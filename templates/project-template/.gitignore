# Transient lock dirs for the atomic id allocators (the counters themselves are
# committed; only the locks aren't)
.TerMinal/backlog/.next-id.lock
.TerMinal/sessions/.next-id.lock
.TerMinal/notes.md

# Live status snapshot — ephemeral, regenerated by .claude/bin/status (committed
# session docs are the durable state; .status.md is the human-facing glance)
.status.md

# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Dependencies / build
node_modules/
dist/
build/
.venv/

# OS / editor cruft
.DS_Store
*.log

# digest intermediates (ephemeral; final .chunks.json + review .md are kept)
.TerMinal/reviews/**/*.scoped.diff
.TerMinal/reviews/**/*.digest-prompt.txt
.TerMinal/reviews/**/*.digest.log
.reviews/**/*.scoped.diff
.reviews/**/*.digest-prompt.txt
.reviews/**/*.digest.log
