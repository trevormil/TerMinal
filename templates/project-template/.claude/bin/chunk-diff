#!/usr/bin/env bun
// chunk-diff — deterministic stage of /digest.
//
// Storage-agnostic: reads a unified diff (+ optional findings.json) and writes a
// chunks.json skeleton. Every changed file becomes one chunk, classified by kind
// + risk with ZERO LLM tokens. 🟢 chunks get a final green_label here and never
// reach the model; non-🟢 chunks are left with empty summary/note for the codex
// digest pass + merge-digest to fill. Works for both the in-repo
// .TerMinal/reviews/ flow and the harness prs/ flow — the caller supplies paths.
// See .agents/digest.md.

import { createHash } from 'crypto';
import { readFile, writeFile } from 'fs/promises';

type Hunk = {
  header: string;
  old_start: number;
  new_start: number;
  addedLines: string[]; // transient — for per-hunk mechanical classification
  removedLines: string[];
  mechanical: boolean; // every changed line is whitespace / import / comment
  label: string; // 'imports' | 'comments' | 'whitespace' | '' (substantive)
};

// What the artifact carries per hunk (no line text — keeps it small).
type HunkOut = { header: string; old_start: number; new_start: number; mechanical: boolean; label: string };

type FileBlock = {
  oldPath: string | null;
  newPath: string | null;
  status: 'modified' | 'added' | 'deleted' | 'renamed' | 'binary';
  hunks: Hunk[];
  added: number;
  deleted: number;
  addedLines: string[];
  removedLines: string[];
  raw: string[]; // verbatim block lines, for emitting a scoped diff
};

type Risk = 'green' | 'yellow' | 'red';

type Chunk = {
  id: string;
  file: string;
  old_path: string | null;
  kind: string;
  risk: Risk;
  risk_reason: string;
  status: FileBlock['status'];
  added: number;
  deleted: number;
  green_label: string | null;
  summary: string | null;
  note: string | null;
  confidence: string | null;
  decision_signals: string[];
  hunks: HunkOut[];
};

function usage(code = 0): never {
  console.log(`Usage: bin/chunk-diff --patch <diff|-> --out <chunks.json|-> [opts]

  --patch <file>       unified diff to chunk (or - for stdin)        [required]
  --out <file>         where to write the chunks.json skeleton (or -) [required]
  --scoped-out <file>  also write a diff of ONLY non-🟢 blocks (the model input)
  --findings <file>    findings.json; open findings pin their file to 🔴
  --pr <repo#number>   header label for the artifact
  --short <sha>        head short sha for the artifact header
  --joint <csv>        mark as a joint MR digest over these member MR numbers
  --meta <meta.json>   read joint/member_mrs from a harness meta.json instead

Writes a chunks.json skeleton: every changed file classified into a chunk with
kind + 🟢/🟡/🔴 risk, zero LLM tokens. See .agents/digest.md.`);
  process.exit(code);
}

async function readStdin(): Promise<string> {
  const chunks: Uint8Array[] = [];
  for await (const chunk of Bun.stdin.stream()) chunks.push(chunk);
  return Buffer.concat(chunks).toString('utf8');
}

async function readJson<T>(path: string, fallback: T): Promise<T> {
  try {
    return JSON.parse(await readFile(path, 'utf8')) as T;
  } catch {
    return fallback;
  }
}

// ── diff parsing ────────────────────────────────────────────────────────────

function parseDiff(patch: string): FileBlock[] {
  const files: FileBlock[] = [];
  let cur: FileBlock | null = null;
  let curHunk: Hunk | null = null;

  for (const line of patch.split('\n')) {
    if (line.startsWith('diff --git ')) {
      if (cur) files.push(cur);
      curHunk = null;
      const m = line.match(/^diff --git a\/(.+?) b\/(.+)$/);
      cur = {
        oldPath: m ? m[1] : null,
        newPath: m ? m[2] : null,
        status: 'modified',
        hunks: [],
        added: 0,
        deleted: 0,
        addedLines: [],
        removedLines: [],
        raw: [line],
      };
      continue;
    }
    if (!cur) continue;
    cur.raw.push(line);

    if (line.startsWith('rename from ')) {
      cur.oldPath = line.slice('rename from '.length);
      cur.status = 'renamed';
    } else if (line.startsWith('rename to ')) {
      cur.newPath = line.slice('rename to '.length);
      cur.status = 'renamed';
    } else if (line.startsWith('new file mode')) {
      if (cur.status === 'modified') cur.status = 'added';
    } else if (line.startsWith('deleted file mode')) {
      cur.status = 'deleted';
    } else if (line.startsWith('Binary files') || line.startsWith('GIT binary patch')) {
      cur.status = 'binary';
    } else if (line.startsWith('@@')) {
      const hm = line.match(/^(@@ -(\d+)(?:,\d+)? \+(\d+)(?:,\d+)? @@)/);
      if (hm) {
        curHunk = {
          header: hm[1],
          old_start: Number(hm[2]),
          new_start: Number(hm[3]),
          addedLines: [],
          removedLines: [],
          mechanical: false,
          label: '',
        };
        cur.hunks.push(curHunk);
      }
    } else if (line.startsWith('+') && !line.startsWith('+++')) {
      cur.added++;
      cur.addedLines.push(line.slice(1));
      curHunk?.addedLines.push(line.slice(1));
    } else if (line.startsWith('-') && !line.startsWith('---')) {
      cur.deleted++;
      cur.removedLines.push(line.slice(1));
      curHunk?.removedLines.push(line.slice(1));
    }
  }
  if (cur) files.push(cur);
  return files;
}

// ── classification (deterministic) ──────────────────────────────────────────

const LOCKFILE = /(^|\/)(bun\.lock|package-lock\.json|pnpm-lock\.yaml|yarn\.lock|Cargo\.lock|go\.sum|poetry\.lock|Gemfile\.lock)$/;
const GENERATED = /(^|\/)(dist|build|out|vendor|node_modules)\/|\.(gen|pb)\.[a-z]+$|\.(snap|min\.js|min\.css)$|_pb2\.py$/;
const DOCS = /\.(md|mdx|rst|txt|adoc)$/;
const TEST = /(^|\/)(test|tests|__tests__|spec|e2e)\/|(\.|-)(test|spec)\.[cm]?[jt]sx?$/;
const CONFIG = /\.(ya?ml|json|toml|ini|cfg|conf)$|(^|\/)\.env/;

// Labeled so a 🔴 chunk can report WHICH surface pinned it (the risk reason).
const SENSITIVE: { label: string; re: RegExp }[] = [
  { label: 'auth', re: /auth|session|login|oauth|jwt|cookie|password|credential/i },
  { label: 'authz', re: /admin|permission|\brole\b|policy|tenant|rbac|authz/i },
  { label: 'payments', re: /payment|checkout|stripe|invoice|billing|balance|ledger|wallet/i },
  { label: 'db/migration', re: /(^|\/)migrations?(\/|$)|(^|\/)schema(\.|\/|$)|\.sql$|prisma|drizzle|mongoose/i },
  { label: 'api route', re: /(^|\/)(api|routes?|controllers?|handlers?|server)\//i },
  { label: 'file-upload', re: /upload|multipart|formdata/i },
  { label: 'crypto', re: /crypto|signing|keypair|secret/i },
];

const IMPORT_LINE = /^\s*(import\s|export\s.*\sfrom\s|from\s.+\simport\s|use\s|using\s|require\()/;
const COMMENT_LINE = /^\s*(\/\/|\/\*|\*\/?|#|--|<!--|;;?|"""|''')/;

// Both FileBlock and Hunk carry addedLines/removedLines, so these work at either
// granularity (whole-file green classification, or per-hunk mechanical collapse).
type Lines = { addedLines: string[]; removedLines: string[] };

function changedLines(x: Lines): string[] {
  return [...x.addedLines, ...x.removedLines].map((l) => l.trim()).filter(Boolean);
}

function isImportOnly(x: Lines): boolean {
  const lines = changedLines(x);
  return lines.length > 0 && lines.every((l) => IMPORT_LINE.test(l));
}

function isCommentOnly(x: Lines): boolean {
  const lines = changedLines(x);
  return lines.length > 0 && lines.every((l) => COMMENT_LINE.test(l));
}

function isWhitespaceOnly(x: Lines): boolean {
  if (x.addedLines.length === 0 && x.removedLines.length === 0) return false;
  const norm = (arr: string[]) => arr.map((l) => l.replace(/\s+/g, '')).filter(Boolean).sort();
  const a = norm(x.addedLines);
  const r = norm(x.removedLines);
  if (a.length !== r.length || a.length === 0) return false;
  return JSON.stringify(a) === JSON.stringify(r);
}

// Per-hunk: is this hunk pure noise (imports/comments/whitespace) the human can
// skip even inside a non-🟢 file? Sets mechanical + a label, in place.
function classifyHunk(h: Hunk): void {
  if (isWhitespaceOnly(h)) {
    h.mechanical = true;
    h.label = 'whitespace';
  } else if (isImportOnly(h)) {
    h.mechanical = true;
    h.label = 'imports';
  } else if (isCommentOnly(h)) {
    h.mechanical = true;
    h.label = 'comments';
  }
}

type Classification = { kind: string; risk: Risk; green_label: string | null; risk_reason: string };

function classify(block: FileBlock, openFindingFiles: Set<string>): Classification {
  const file = block.newPath ?? block.oldPath ?? '';
  const green = (kind: string, label: string): Classification => ({
    kind,
    risk: 'green',
    green_label: label,
    risk_reason: label,
  });

  // Pure rename (R100, no content delta) — green.
  if (block.status === 'renamed' && block.hunks.length === 0) {
    return green('rename', `rename ${block.oldPath} → ${block.newPath}`);
  }
  if (LOCKFILE.test(file)) return green('lockfile', 'lockfile bump');
  if (GENERATED.test(file)) return green('generated', 'generated');
  if (DOCS.test(file)) return green('docs', 'docs');
  if (block.status !== 'binary' && isImportOnly(block)) return green('format', 'import reorder');
  if (block.status !== 'binary' && isWhitespaceOnly(block)) return green('format', 'whitespace-only');
  if (block.status !== 'binary' && isCommentOnly(block)) return green('comment', 'comments only');

  let kind = 'logic';
  if (TEST.test(file)) kind = 'test';
  else if (CONFIG.test(file)) kind = 'config';

  // Risk floor: sensitive surface or an open finding pins to red (LLM can't lower it).
  if (kind !== 'test') {
    if (openFindingFiles.has(file)) return { kind, risk: 'red', green_label: null, risk_reason: 'open finding' };
    const surface = SENSITIVE.find((s) => s.re.test(file));
    if (surface) return { kind, risk: 'red', green_label: null, risk_reason: surface.label };
  }
  return { kind, risk: 'yellow', green_label: null, risk_reason: kind };
}

// Deterministic detection of architecture/design-decision CANDIDATES. These are
// hints that point the bounded codex pass at decision-bearing chunks; the model
// synthesizes the actual decision list (what/why/reversibility) and prunes
// false positives. See .agents/digest.md → "Architecture & design decisions".
function decisionSignals(block: FileBlock): string[] {
  const file = block.newPath ?? block.oldPath ?? '';
  const added = block.addedLines.join('\n');
  const sig = new Set<string>();

  // data-model — schemas, migrations, ORM models, new persisted/data types
  if (
    /schema|(^|\/)migrations?\/|(^|\/)models?\/|entit/i.test(file) ||
    /\.sql$/i.test(file) ||
    /\b(create table|alter table|add column|drop column|@entity|@column|new schema\(|definetable|createtable|addcolumn|belongsto|hasmany|primarykey)\b/i.test(added) ||
    /^\s*export\s+(type|interface|enum)\s/m.test(added)
  ) {
    sig.add('data-model');
  }
  // api-contract — routes, handlers, request/response surface
  if (
    /(^|\/)(api|routes?|controllers?|handlers?|graphql)\//i.test(file) ||
    /\b(app|router|fastify|server)\.(get|post|put|patch|delete)\(|@(Get|Post|Put|Patch|Delete|Route)\(|add(Route|Handler)\(|register(Route|Handler)\b/.test(added)
  ) {
    sig.add('api-contract');
  }
  // service-selection — new dependency in a manifest, or wiring an external service client
  if (
    /(^|\/)(package\.json|Cargo\.toml|go\.mod|pyproject\.toml|requirements.*\.txt|Gemfile)$/.test(file) ||
    /\bnew\s+(Client|Pool|Redis|Kafka|S3Client|Stripe|OpenAI|Anthropic|PrismaClient|Mongo\w*)\(|createClient\(|connect\(/.test(added)
  ) {
    sig.add('service-selection');
  }
  // system-design / abstraction — a brand-new source module, or a new exported class/abstraction
  if (
    (block.status === 'added' && /\.(ts|tsx|js|jsx|go|py|rs|rb|java|kt)$/.test(file) && !TEST.test(file)) ||
    /^\s*export\s+(default\s+)?(abstract\s+)?class\s|^\s*export\s+(default\s+)?function\s|createServer\(|new\s+\w+Service\(/m.test(added)
  ) {
    sig.add('system-design');
  }
  // security-model — auth/authz/crypto policy surfaces
  if (
    /auth|authz|crypto|permission|\brole\b|guard|middleware/i.test(file) &&
    /\b(authorize|can[A-Z]\w*|permission|verify\w*token|hashpassword|encrypt|sign\w*|policy|guard)\b/i.test(added)
  ) {
    sig.add('security-model');
  }
  return [...sig];
}

function chunkId(file: string, hunks: Hunk[]): string {
  return createHash('sha256')
    .update(`${file}\n${hunks.map((h) => h.header).join('\n')}`)
    .digest('hex')
    .slice(0, 8);
}

async function main() {
  const argv = [...Bun.argv.slice(2)];
  const opt: Record<string, string> = {};
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '-h' || a === '--help') usage(0);
    else if (a.startsWith('--')) opt[a.slice(2)] = argv[++i];
    else usage(1);
  }
  if (!opt.patch || !opt.out) usage(1);

  const patch = opt.patch === '-' ? await readStdin() : await readFile(opt.patch, 'utf8');
  const meta = opt.meta ? await readJson<any>(opt.meta, null) : null;
  const findings = opt.findings
    ? await readJson<{ findings: { file: string; status: string }[] }>(opt.findings, { findings: [] })
    : { findings: [] };
  const openFindingFiles = new Set(
    findings.findings
      .filter((f) => f.status === 'open')
      .map((f) => f.file.replace(/:\d+.*$/, ''))
      .filter(Boolean),
  );

  const blocks = parseDiff(patch);
  const scopedBlocks: string[] = []; // raw diff of non-🟢 blocks, for the scoped model input
  const chunks: Chunk[] = blocks.map((block) => {
    const file = block.newPath ?? block.oldPath ?? 'unknown';
    const { kind, risk, green_label, risk_reason } = classify(block, openFindingFiles);
    block.hunks.forEach(classifyHunk);
    if (risk !== 'green') scopedBlocks.push(block.raw.join('\n'));
    return {
      id: chunkId(file, block.hunks),
      file,
      old_path: block.status === 'renamed' ? block.oldPath : null,
      kind,
      risk,
      risk_reason,
      status: block.status,
      added: block.added,
      deleted: block.deleted,
      green_label,
      summary: null,
      note: null,
      confidence: null,
      decision_signals: green_label ? [] : decisionSignals(block),
      hunks: block.hunks.map((h) => ({
        header: h.header,
        old_start: h.old_start,
        new_start: h.new_start,
        mechanical: h.mechanical,
        label: h.label,
      })),
    };
  });

  const rank: Record<Risk, number> = { red: 0, yellow: 1, green: 2 };
  chunks.sort((a, b) => rank[a.risk] - rank[b.risk] || a.file.localeCompare(b.file));

  const count = (r: Risk) => chunks.filter((c) => c.risk === r).length;
  const out = {
    pr: opt.pr ?? null,
    short_sha: opt.short ?? null,
    kind: 'digest',
    generated: new Date().toISOString(),
    generator: 'chunk-diff',
    joint: opt.joint
      ? { member_mrs: opt.joint.split(',').map((n) => n.trim()).filter(Boolean) }
      : meta?.joint && Array.isArray(meta.member_mrs)
        ? { member_mrs: meta.member_mrs }
        : false,
    brief: null,
    blast_radius: null,
    diagrams: [],
    double_check: [],
    // Synthesized by the codex digest pass from the per-chunk decision_signals below.
    decisions: [],
    decision_candidates: chunks
      .filter((c) => c.decision_signals.length > 0)
      .map((c) => ({ file: c.file, chunk_id: c.id, signals: c.decision_signals })),
    stats: {
      files: chunks.length,
      chunks: chunks.length,
      green: count('green'),
      yellow: count('yellow'),
      red: count('red'),
      llm_chunks: chunks.filter((c) => c.risk !== 'green').length,
      added: chunks.reduce((n, c) => n + c.added, 0),
      deleted: chunks.reduce((n, c) => n + c.deleted, 0),
    },
    chunks,
  };

  const serialized = JSON.stringify(out, null, 2) + '\n';
  if (opt.out === '-') process.stdout.write(serialized);
  else await writeFile(opt.out, serialized, 'utf8');

  // Scoped diff: only the non-🟢 blocks — what the model actually needs. 🟢
  // content (lockfiles, generated, docs, whitespace) never reaches the LLM.
  let scopedNote = '';
  if (opt['scoped-out']) {
    const scoped = scopedBlocks.length ? scopedBlocks.join('\n') + '\n' : '';
    await writeFile(opt['scoped-out'], scoped, 'utf8');
    const pct = patch.length ? Math.round((1 - scoped.length / patch.length) * 100) : 0;
    scopedNote = `; scoped input ${scoped.length}/${patch.length} chars (−${pct}% vs full diff)`;
  }

  console.error(
    `${out.stats.chunks} chunks — ${out.stats.red}🔴 ${out.stats.yellow}🟡 ${out.stats.green}🟢; ` +
      `${out.stats.llm_chunks}/${out.stats.chunks} need the model; ` +
      `${out.decision_candidates.length} design-decision candidate(s)${scopedNote}`,
  );
}

main().catch((error) => {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
});
