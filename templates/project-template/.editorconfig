# https://editorconfig.org — uniform whitespace across editors; kills noisy diffs.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false   # trailing spaces are significant (hard line break)

[Makefile]
indent_style = tab

[*.{go,go.mod,go.sum}]
indent_style = tab
