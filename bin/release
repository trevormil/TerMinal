#!/usr/bin/env bash
# release — full rebuild of the macOS app + reinstall to /Applications.
#
# Packages (electron-vite build + electron-builder), deep ad-hoc signs (so it
# launches on Apple Silicon), quits the running copy, installs to /Applications,
# and relaunches. This is the "full re-build" flow — run it after changes so the
# installed app is current. (True self-update via electron-updater needs an Apple
# Developer ID signature + notarization; see docs/runbooks/build-and-release.md.)
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
# electron-builder emits the .app under dist/mac-arm64 (Apple Silicon),
# dist/mac (Intel), or dist/mac-universal — no arch is pinned. Glob for
# whichever the build actually produced (newest first) instead of guessing by
# host arch, which is wrong under Rosetta and misses universal builds.
APP="$(ls -dt dist/mac*/TerMinal.app 2>/dev/null | head -n1 || true)"
if [[ -z "$APP" ]]; then
  echo "release: no built app under dist/mac*/TerMinal.app — run the build first" >&2
  exit 1
fi
DEST="${TERMINAL_APP_DEST:-/Applications/TerMinal.app}"

sync_latest() {
  if [[ "${TERMINAL_RELEASE_SKIP_PULL:-}" == "1" ]]; then
    echo "▸ latest check: skipped (TERMINAL_RELEASE_SKIP_PULL=1)"
    return
  fi

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "▸ latest check: skipped (not a git checkout)"
    return
  fi

  if ! git remote get-url origin >/dev/null 2>&1; then
    echo "▸ latest check: skipped (no origin remote)"
    return
  fi

  echo "▸ latest check: fetching origin…"
  git fetch --quiet --prune origin

  local default_branch
  default_branch="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##' || true)"
  if [[ -z "$default_branch" ]]; then
    if git rev-parse --verify --quiet refs/remotes/origin/main >/dev/null; then
      default_branch="main"
    elif git rev-parse --verify --quiet refs/remotes/origin/master >/dev/null; then
      default_branch="master"
    fi
  fi
  if [[ -z "$default_branch" ]]; then
    echo "▸ latest check: skipped (could not detect origin default branch)"
    return
  fi

  local current_branch
  current_branch="$(git branch --show-current)"
  if [[ "$current_branch" != "$default_branch" ]]; then
    echo "▸ latest check: on $current_branch, not $default_branch; building current checkout"
    return
  fi

  if [[ -n "$(git status --porcelain)" ]]; then
    echo "▸ latest check: local changes present; building current checkout"
    return
  fi

  local local_sha remote_ref remote_sha base_sha
  remote_ref="refs/remotes/origin/$default_branch"
  local_sha="$(git rev-parse HEAD)"
  remote_sha="$(git rev-parse "$remote_ref")"
  base_sha="$(git merge-base HEAD "$remote_ref")"

  if [[ "$local_sha" == "$remote_sha" ]]; then
    echo "▸ latest check: already at origin/$default_branch"
  elif [[ "$local_sha" == "$base_sha" ]]; then
    echo "▸ latest check: fast-forwarding to origin/$default_branch…"
    git merge --ff-only "$remote_ref"
  else
    echo "▸ latest check: local $default_branch is ahead or diverged; building current checkout"
  fi

  if [[ -f .gitmodules ]]; then
    git submodule update --init --recursive
  fi
}

sync_latest

echo "▸ building…"
bun run dist

echo "▸ ad-hoc signing…"
codesign --force --deep --sign - "$APP"
codesign --verify --deep --strict "$APP"

echo "▸ installing → ${DEST}…"
pkill -f "$DEST/Contents/MacOS" 2>/dev/null || true
sleep 1
rm -rf "$DEST"
cp -R "$APP" "$DEST"
xattr -cr "$DEST"

echo "▸ launching…"
open "$DEST"
echo "✓ released → $DEST"
