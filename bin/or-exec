#!/usr/bin/env bun
// or-exec — raw single-shot completion via OpenRouter (the cheap tier's
// NON-agentic path). Prompt in, text out; the caller applies the output.
// For work that must read/edit files, use `or-agent` (Codex-driven) instead.
//
// Usage:
//   or-exec --model deepseek/deepseek-chat --prompt "…"
//   echo "…" | or-exec                     # uses registry raw default
//   or-exec --model <slug> --allow-expensive --prompt "…"
//
// Budget: enforces the daily $ pool AND, when OR_SESSION is set, the per-session
// cap (both from ~/.claude/model-routing/models.json). Every call is logged to
// spend.jsonl. Exhaustion exits non-zero (use your own model) — never overspends.
// See skill: outsource. The downgrade gate still governs *whether* to route here.

import { loadRegistry, readSpend, logSpend, summarize, budgetBlock } from "../model-routing/lib.ts"

const args = process.argv.slice(2)
const flag = (n: string) => { const i = args.indexOf(n); return i >= 0 ? args[i + 1] : undefined }
const has = (n: string) => args.includes(n)

const reg = await loadRegistry()
const model = flag("--model") ?? reg.defaults?.raw
const allowExpensive = has("--allow-expensive")
const maxTokens = Number(flag("--max-tokens") ?? reg.budget?.perCallMaxTokens ?? 8000)
const session = process.env.OR_SESSION ?? null

const key = process.env.OPENROUTER_API_KEY
if (!key) { console.error("or-exec: OPENROUTER_API_KEY not set"); process.exit(2) }
if (!model) { console.error("or-exec: no --model and no registry raw default"); process.exit(2) }

// Footgun guard: this tier is for near-free models.
const EXPENSIVE = /(opus|gpt-5|o[13]-mini|o[13]-preview|gpt-4\.5|grok-.*heavy)/i
if (EXPENSIVE.test(model) && !allowExpensive) {
  console.error(`or-exec: '${model}' looks like an expensive frontier model — pass --allow-expensive to authorize (near-free tier guard)`)
  process.exit(2)
}

// Budget guard (daily pool + per-session cap).
const over = budgetBlock(reg, summarize(await readSpend(), { session }), session)
if (over) { console.error(`or-exec: ${over}`); process.exit(3) }

let prompt = flag("--prompt")
if (!prompt) prompt = await Bun.stdin.text()
prompt = (prompt ?? "").trim()
if (!prompt) { console.error("or-exec: no prompt (pass --prompt or pipe via stdin)"); process.exit(2) }

const started = performance.now()
const res = await fetch("https://openrouter.ai/api/v1/chat/completions", {
  method: "POST",
  headers: {
    Authorization: `Bearer ${key}`,
    "Content-Type": "application/json",
    "HTTP-Referer": "https://github.com/trevormiller/dotclaude",
    "X-Title": "or-exec",
  },
  body: JSON.stringify({ model, messages: [{ role: "user", content: prompt }], max_tokens: maxTokens, usage: { include: true } }),
})

if (!res.ok) {
  const body = await res.text()
  console.error(`or-exec: OpenRouter ${res.status} — ${body.slice(0, 500)}`)
  process.exit(1)
}

const data: any = await res.json()
const ms = Math.round(performance.now() - started)
const text = data?.choices?.[0]?.message?.content ?? ""
const usage = data?.usage ?? {}
const meta = { ts: new Date().toISOString(), harness: "openrouter", model, session, tokensIn: usage.prompt_tokens ?? null, tokensOut: usage.completion_tokens ?? null, cost: usage.cost ?? 0, ms }

await logSpend(meta)
console.error(JSON.stringify(meta))
if (has("--json")) console.log(JSON.stringify({ text, meta }))
else console.log(text)
